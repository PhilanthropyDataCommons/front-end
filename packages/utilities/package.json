{
	"name": "@pdc/utilities",
	"description": "Utilities for PDC frontend applications",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"lint": "npm run lint:eslint && npm run lint:prettier && npm run lint:tsc",
		"lint:prettier": "prettier . --check --ignore-path ../../.gitignore",
		"lint:eslint": "eslint --report-unused-disable-directives --max-warnings 0",
		"lint:tsc": "vue-tsc --noEmit",
		"test": "vitest --run",
		"format": "npm run format:prettier && npm run format:eslint",
		"format:prettier": "prettier . --write  --ignore-path ../../.gitignore",
		"format:eslint": "eslint --fix || true"
	},
	"exports": {
		".": "./src/index.ts"
	},
	"dependencies": {
		"@dsb-norge/vue-keycloak-js": "^3.0.7",
		"@pdc/sdk": "^0.36.1",
		"@vitejs/plugin-vue": "^6.0.7",
		"@vue/compiler-sfc": "^3.5.34",
		"dayjs": "^1.11.20",
		"jsonpath-plus": "^10.4.0",
		"luxon": "^3.7.2",
		"pino": "^10.1.0",
		"qs": "^6.15.2",
		"vitest": "^4.1.7",
		"vue": "^3.5.34",
		"vue-router": "^5.0.7",
		"web-vitals": "^5.2.0"
	}
}
